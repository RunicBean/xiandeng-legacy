{
    // 使用 IntelliSense 了解相关属性。 
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "task",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "cwd": "${workspaceFolder}/xiandeng-server",
            "program": "${workspaceFolder}/xiandeng-server/cmd/task/main.go",
            // "args": ["worker"]
            "args": ["-env", "dev"]
        },
        {
            "name": "server",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/xiandeng-server/cmd/server/main.go",
            "cwd": "${workspaceFolder}/xiandeng-server",
            "args": ["-env", "dev"]
        },
        {
            "name": "test",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${workspaceFolder}/xiandeng-server/tests",
            "args": [
                "./..."
            ],
            "env": {},
            "cwd": "${workspaceFolder}/xiandeng-server",
            "showLog": true,
            "trace": "info"
        },
        {
            "name": "Launch via NPM",
            "request": "launch",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "runtimeExecutable": "yarn",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node",
            "cwd": "${workspaceFolder}/xiandeng-web",
            "envFile": "${workspaceFolder}/xiandeng-web/.vscode/.env"
        },

    ]
}